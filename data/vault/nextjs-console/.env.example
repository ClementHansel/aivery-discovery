# VPS Bridge Configuration
# Note: VPS Bridge runs in internal-only mode (network isolation).
# No API key is required — do NOT set VPS_BRIDGE_API_KEY.
VPS_BRIDGE_URL=http://localhost:3003

# n8n Configuration
NEXT_PUBLIC_N8N_EDITOR_BASE_URL=http://localhost:5678

# Composio OAuth (manages all OAuth providers + app connections)
# Get your API key from https://app.composio.dev → Settings
COMPOSIO_API_KEY=your-composio-api-key
COMPOSIO_REDIRECT_URL=https://your-domain.com/integrations/callback
