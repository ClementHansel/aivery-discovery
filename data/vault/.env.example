# ══════════════════════════════════════════════════════════════════════════════
# AIVORY — UNIFIED ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your actual values
# This single file configures ALL services:
#   - Python Backend (FastAPI)
#   - VPS Bridge (PicoClaw Gateway)
#   - Next.js Console (+ Composio OAuth)
# ══════════════════════════════════════════════════════════════════════════════

# ── Python Backend (FastAPI :8081) ────────────────────────────────────────────
HOST=0.0.0.0
PORT_BACKEND=8081

# ── OpenRouter AI (shared by Python backend + VPS Bridge) ─────────────────────
# Get your API key from https://openrouter.ai
OPENROUTER_API_KEY=sk-or-your-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Authentication (Python backend) ──────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production-use-long-random-string
SUPERADMIN_PASSWORD=your-superadmin-password-here

# ── n8n Integration (shared by Python backend + VPS Bridge) ──────────────────
N8N_BASE_URL=http://127.0.0.1:5678
N8N_API_KEY=your-n8n-api-key-here
N8N_WORKFLOW_ID=your-workflow-id
N8N_TIMEOUT=10.0
N8N_MAX_RETRIES=3

# ── n8n-MCP Server (node schema validation) ──────────────────────────────────
N8N_MCP_URL=http://127.0.0.1:3020
N8N_MCP_AUTH_TOKEN=your-mcp-auth-token

# ── VPS Bridge (PicoClaw Gateway :3003) ──────────────────────────────────────
VPS_BRIDGE_PORT=3003
VPS_BRIDGE_URL=http://localhost:3003
VPS_BRIDGE_API_KEY=your-vps-bridge-api-key
VPS_BRIDGE_CORS_ORIGIN=http://localhost:3000
VPS_BRIDGE_LOG_LEVEL=info

# ── Zeroclaw Orchestrator ────────────────────────────────────────────────────
ZEROCLAW_URL=http://localhost:42617
ZEROCLAW_TOKEN=
ZEROCLAW_BASE_URL=http://127.0.0.1:3010

# ── Composio OAuth (manages all OAuth providers + app connections) ────────────
# Get your API key from https://app.composio.dev → Settings
COMPOSIO_API_KEY=your-composio-api-key
COMPOSIO_REDIRECT_URL=https://your-domain.com/integrations/callback

# ── Next.js Console (:3000) ──────────────────────────────────────────────────
NEXT_PUBLIC_CONSOLE_PORT=3000
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_VPS_BRIDGE_URL=http://localhost:3003
NEXT_PUBLIC_VPS_BRIDGE_API_KEY=your-vps-bridge-api-key
NEXT_PUBLIC_N8N_EDITOR_BASE_URL=http://localhost:5678

# ── Legacy / Production Override ─────────────────────────────────────────────
# BRIDGE_BASE_URL=http://your-production-server:3001
